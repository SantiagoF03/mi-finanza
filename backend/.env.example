# Mi Finanza MVP — variables de entorno
# Copiá este archivo a .env y completá los valores reales.
# Todas las variables tienen default seguro en app/core/config.py.

# ── Entorno ──────────────────────────────────────────────────────────
ENVIRONMENT=dev
DATABASE_URL=sqlite:///./mi_finanza.db

# ── Broker IOL ───────────────────────────────────────────────────────
# mock = sin credenciales, datos simulados. real = opera contra IOL.
BROKER_MODE=mock
IOL_USERNAME=
IOL_PASSWORD=
IOL_PORTFOLIO_COUNTRY=argentina
IOL_TIMEOUT_SECONDS=15

# ── Noticias ─────────────────────────────────────────────────────────
# mock | rss
NEWS_PROVIDER=rss
NEWS_TIMEOUT_SECONDS=10
NEWS_MAX_ITEMS=20

# ── Scheduler (horas en UTC; BYMA: 11=08:00 ART, 20=17:00 ART) ──────
SCHEDULER_ENABLED=true
SCHEDULER_MARKET_OPEN_HOUR=11
SCHEDULER_MARKET_CLOSE_HOUR=20
SCHEDULER_OPEN_INTERVAL_MINUTES=30
SCHEDULER_POSTMARKET_FORCE_CYCLE=false

# ── Perfil de inversor ───────────────────────────────────────────────
# conservative | moderate | moderate_aggressive | aggressive
INVESTOR_PROFILE_TARGET=moderate_aggressive
MAX_MOVEMENT_PER_CYCLE=0.10

# ── LLM (GPT) — solo explica, nunca decide ni ejecuta ───────────────
LLM_ENABLED=false
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=15

# ── Notificaciones ───────────────────────────────────────────────────
NOTIFICATION_ENABLED=true
# telegram | web_push
NOTIFICATION_CHANNEL=web_push
NOTIFICATION_MIN_SEVERITY=medium
NOTIFICATION_COOLDOWN_SECONDS=300
NOTIFICATION_CONTRADICTION_THRESHOLD=3
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Web Push (generar con: npx web-push generate-vapid-keys) ────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=

# ── Pipeline ─────────────────────────────────────────────────────────
USE_CLUSTERS=false

# ── Seguridad ────────────────────────────────────────────────────────
# API key para endpoints sensibles (approve/reject/settings/debug).
# Vacío = sin autenticación (solo dev local).
API_KEY=
# CORS origins (CSV). "*" = permitir todo (solo dev).
CORS_ORIGINS=*

# ── Debug ────────────────────────────────────────────────────────────
# Deshabilitar en producción: bloquea POST /debug/simulate-alert con 403.
DEBUG_ENDPOINTS_ENABLED=true

# ── Universo de activos (CSV) ────────────────────────────────────────
WHITELIST_ASSETS=AAPL,MSFT,SPY,QQQ,AL30,BND,CASH
WATCHLIST_ASSETS=
MARKET_UNIVERSE_ASSETS=
