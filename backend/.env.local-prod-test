# Mi Finanza — Local production test (mock broker, GPT ON, push ON)
# Simula entorno real sin operar contra IOL.
# Copiar a .env antes de levantar.

ENVIRONMENT=staging

# ── Base de datos (archivo persistente) ─────────────────────────────
DATABASE_URL=sqlite:///./mi_finanza.db

# ── Broker (mock — no opera contra IOL) ─────────────────────────────
BROKER_MODE=mock
IOL_USERNAME=
IOL_PASSWORD=

# ── Noticias (RSS real) ─────────────────────────────────────────────
NEWS_PROVIDER=rss
NEWS_TIMEOUT_SECONDS=10
NEWS_MAX_ITEMS=20

# ── Scheduler (activo, horarios BYMA en UTC) ────────────────────────
SCHEDULER_ENABLED=true
SCHEDULER_MARKET_OPEN_HOUR=11
SCHEDULER_MARKET_CLOSE_HOUR=20
SCHEDULER_OPEN_INTERVAL_MINUTES=30

# ── Perfil ──────────────────────────────────────────────────────────
INVESTOR_PROFILE_TARGET=moderate_aggressive
MAX_MOVEMENT_PER_CYCLE=0.10

# ── GPT (ON — solo explica, nunca decide ni ejecuta) ────────────────
LLM_ENABLED=true
LLM_PROVIDER=openai
LLM_API_KEY=sk-COMPLETAR
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=15

# ── Push notifications (ON) ─────────────────────────────────────────
NOTIFICATION_ENABLED=true
NOTIFICATION_CHANNEL=web_push
NOTIFICATION_MIN_SEVERITY=medium
NOTIFICATION_COOLDOWN_SECONDS=300
VAPID_PUBLIC_KEY=COMPLETAR
VAPID_PRIVATE_KEY=COMPLETAR
VAPID_CONTACT_EMAIL=santiferreyra003@gmail.com

# ── Seguridad ───────────────────────────────────────────────────────
# API_KEY debe coincidir con VITE_API_KEY del frontend (single-user).
API_KEY=COMPLETAR-CON-TOKEN-SEGURO
CORS_ORIGINS=https://tu-dominio.com
DEBUG_ENDPOINTS_ENABLED=false

# ── Assets ──────────────────────────────────────────────────────────
WHITELIST_ASSETS=AAPL,MSFT,SPY,QQQ,AL30,BND,CASH
