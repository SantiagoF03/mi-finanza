# Mi Finanza frontend — variables de entorno (Vite)
# Copiá este archivo a .env (o .env.production para el build).

# URL base del backend (sin /api).
# Vacío = /api relativo (same-origin): producción con Caddy y dev con proxy de Vite.
# Con valor = backend en otro host, ej: http://192.168.0.10:8000
VITE_API_BASE=

# API key para endpoints sensibles (approve/reject/settings/analysis/push-test).
# DEBE coincidir con API_KEY del backend (app single-user).
# Vacío = no se manda header (solo válido si el backend tiene API_KEY vacío).
# ⚠️  Vite embebe esta key en el bundle JS: cualquiera con acceso a la app
#     puede leerla. Aceptable para single-user; no para multi-usuario.
VITE_API_KEY=
